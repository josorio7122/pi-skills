{
  "name": "pi-skills",
  "version": "1.0.0",
  "description": "Personal pi skills collection",
  "scripts": {
    "test": "vitest run",
    "lint": "biome check skills/ tests/",
    "format": "biome format --write skills/ tests/",
    "format:check": "biome format skills/ tests/",
    "lint:fix": "biome check --fix skills/ tests/",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck && npm run test"
  },
  "keywords": [
    "pi-package"
  ],
  "author": "",
  "license": "ISC",
  "private": "true",
  "pi": {
    "skills": [
      "./skills"
    ]
  },
  "type": "module",
  "dependencies": {
    "exa-js": "^2.10.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.2"
  }
}
